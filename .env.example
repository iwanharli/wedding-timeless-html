# ==========================================
# ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this file to .env and fill in the values below.
# Defaults are for local development; production values are
# given as commented-out examples where they differ.

# 1. PostgreSQL Database Connection String
DATABASE_URL=postgresql://localhost:5432/db_wedding
# Production example:
# DATABASE_URL=postgresql://wedding_user:your_secure_password@localhost:5432/db_wedding

# 2. Secret Key for JWT Auth (must be a long random string)
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# 3. Backend API Port (Express)
PORT=4000

# 4. Frontend API Endpoint (Vite)
# Local dev: point to the local backend port above
VITE_API_BE_URL=http://localhost:4000
# Production: leave empty if frontend & backend are served from the same
# domain (relative paths), or set to your backend API domain
# (e.g. https://api.domain-anda.com) if hosted separately.
# VITE_API_BE_URL=
